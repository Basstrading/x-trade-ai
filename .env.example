# ═══════════════════════════════════════════════
# RISK DESK — Configuration
# ═══════════════════════════════════════════════

# Prop firm: topstep, apex, bulenox, tradeify, tpt
PROP_FIRM=topstep

# Plan: depends de la prop firm
# topstep: 50k, 100k, 150k
# apex: 25k, 50k, 100k, 150k
# bulenox: 25k_opt1, 25k_opt2, 50k_opt1, 50k_opt2, 100k_opt1, etc.
# tradeify: 50k, 100k, 150k
# tpt: 25k, 50k, 75k, 100k, 150k
TOPSTEP_ACCOUNT_TYPE=50k

# Instrument: MNQ, NQ, MES, ES, CL, GC, etc.
INSTRUMENT=MNQ

# Nom du trader
TRADER_ID=trader_1

# Port du serveur
TRADING_PORT=8001

# Cle admin (generee automatiquement au premier lancement si absente)
# RISK_DESK_ADMIN_KEY=votre_cle_ici

# ═══════════════════════════════════════════════
# STRIPE (paiement $29/compte/mois)
# ═══════════════════════════════════════════════
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...          (cree dans Stripe Dashboard > Products)
# STRIPE_WEBHOOK_SECRET=whsec_...    (cree dans Stripe Dashboard > Webhooks)
# APP_URL=https://x-trade.ai        (URL publique pour les redirections)

# ═══════════════════════════════════════════════
# TOPSTEPX API (optionnel — pour le trading live)
# ═══════════════════════════════════════════════
# PROJECTX_USERNAME=
# PROJECTX_API_KEY=
# PROJECTX_API_URL=https://api.topstepx.com
# ACCOUNT_ID=
